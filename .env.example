# ---------------------------------------------------------------------------
# Auth / session security
# ---------------------------------------------------------------------------

# High-entropy secret used to HMAC-sign and verify the `crm_op_session` token.
# REQUIRED on the server. `lib/session.ts` fails fast (refuses to sign/verify)
# when this is unset. Never expose this to the browser. Generate with e.g.
#   openssl rand -base64 48
SESSION_SECRET=

# Owner/account identifier (UUID) previously hardcoded in lib/auth.ts.
# Use NEXT_PUBLIC_OWNER_ID when it must be read in client components;
# OWNER_ID (server-only) is used as a fallback by lib/config.ts.
NEXT_PUBLIC_OWNER_ID=
OWNER_ID=

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Public Supabase project URL and anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Bootstrap admin credentials (optional)
# ---------------------------------------------------------------------------
# Used to seed/recover the initial admin account. Keep REAL values out of
# source control — set these only in your deployment's secret storage.
CRM_BOOTSTRAP_PHONE=
CRM_BOOTSTRAP_PASSWORD=
